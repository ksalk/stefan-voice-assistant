    "DecoderFile": "decoder-epoch-13-avg-2-chunk-16-left-64.onnx",
    "JoinerFile": "joiner-epoch-13-avg-2-chunk-16-left-64.onnx",
    "TokensPath": "tokens.txt",
    "KeywordsFile": "keywords.txt",
    "NumThreads": 2,
    "Provider": "cpu",
    "FeatureDim": 80
  }
}
