{
  "Node": {
    "Name": "stefan-node"
  },
  "Server": {
    "Url": "http://0.0.0.0:8080"
  },
  "RemoteServer": {
    "Url": "http://127.0.0.1:5285",
    "AuthSecret": "dev-secret-change-me"
  },
  "Audio": {
    "Input": {
      "DeviceName": "plughw:0,0",
      "SampleRate": 48000,
      "Channels": 1,
