# ---------------------------------------------------------------------------
# Remote server
# ---------------------------------------------------------------------------

# URL the node POSTs captured audio to
SERVER_URL=http://localhost:5285/command

# WebSocket URL for persistent server connection (currently unused)
SERVER_WS_URL=wss://localhost:7036/ws

# Shared secret sent as the X-Node-Secret header — must match the server config
NODE_SECRET=

# ---------------------------------------------------------------------------
# Local HTTP server
# ---------------------------------------------------------------------------

# Address to bind the local health/text endpoint on
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# ---------------------------------------------------------------------------
# Wake word detection
# ---------------------------------------------------------------------------

# Confidence score threshold to trigger wake word (0.0–1.0)
WAKEWORD_THRESHOLD=0.6

# Minimum seconds between two consecutive wake word triggers
WAKEWORD_COOLDOWN=1.5

# Milliseconds of audio to discard immediately after wake word detection
# (trims the trailing "alexa" sound from the command recording)
WAKEWORD_SKIP_MS=200

# ---------------------------------------------------------------------------
# Voice command recording
# ---------------------------------------------------------------------------

# RMS energy level (int16) below which audio is considered silence
SILENCE_THRESHOLD=200

# Seconds of consecutive silence required to stop recording
SILENCE_DURATION=1.0

# Hard cap on recording length in seconds
MAX_RECORD_DURATION=10.0

# Directory where timestamped command WAVs are saved
OUTPUT_DIR=./recordings

# ---------------------------------------------------------------------------
# TTS (piper) — path to the .onnx model file
# ---------------------------------------------------------------------------

# Absolute or relative (to project root) path to the piper voice model
PIPER_MODEL=models/en_US-hfc_female-medium.onnx
