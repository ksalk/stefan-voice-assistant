# ---------------------------------------------------------------------------
# Node
# ---------------------------------------------------------------------------

# Human-readable name that uniquely identifies this node
NODE_NAME=my-node

# ---------------------------------------------------------------------------
# Remote server
# ---------------------------------------------------------------------------

# URL the node POSTs captured audio to
REMOTE_SERVER_URL=http://localhost:5285

# WebSocket URL for persistent server connection
REMOTE_SERVER_WS_URL=wss://localhost:7036/ws

# Shared secret sent as the X-Node-Secret header — must match the server config
REMOTE_SERVER_AUTH_SECRET=

# Enable TLS certificate verification (set to true for production with a trusted cert)
REMOTE_SERVER_SSL_VERIFY=false

# ---------------------------------------------------------------------------
# Local HTTP server
# ---------------------------------------------------------------------------

# Address to bind the local health/text endpoint on
LOCAL_SERVER_HOST=0.0.0.0
LOCAL_SERVER_PORT=8080

# ---------------------------------------------------------------------------
# Audio input
# ---------------------------------------------------------------------------

# Input device index (leave unset to use the system default)
# AUDIO_INPUT_DEVICE=

# ---------------------------------------------------------------------------
# Wake word detection
# ---------------------------------------------------------------------------

# Confidence score threshold to trigger wake word (0.0–1.0)
AUDIO_WAKEWORD_THRESHOLD=0.6

# Minimum seconds between two consecutive wake word triggers
AUDIO_WAKEWORD_COOLDOWN=1.5

# Milliseconds of audio to discard immediately after wake word detection
# (trims the trailing "alexa" sound from the command recording)
AUDIO_SKIP_MS_AFTER_WAKEWORD=200

# ---------------------------------------------------------------------------
# Voice command recording
# ---------------------------------------------------------------------------

# RMS energy level (int16) below which audio is considered silence
AUDIO_END_SILENCE_THRESHOLD=200

# Seconds of consecutive silence required to stop recording
AUDIO_END_SILENCE_DURATION=1.0

# Hard cap on recording length in seconds
AUDIO_MAX_RECORDING_DURATION=10.0

# Directory where timestamped command WAVs are saved
AUDIO_RECORDINGS_OUTPUT_DIR=./recordings

# ---------------------------------------------------------------------------
# TTS (piper)
# ---------------------------------------------------------------------------

# Path to the piper voice model .onnx file (relative to the node app root)
TTS_PIPER_MODEL=models/en_US-hfc_female-medium.onnx
